ess colony growth in the mutant compared to wildtype (PMID: 18762571, 10229196, 25584008).		True	TP53, a tumor suppressor in the DNA damage pathway, is the most frequently mutated gene in cancer.	True	06/11/2024	Likely Oncogenic	25584008|18762571|10229196	[{"levelOfEvidence":"LEVEL_Px1","alterations":["Oncogenic Mutations"],"tumorType":{"id":505,"code":"MDS","color":"LightSalmon","name":"Myelodysplastic Syndromes","mainType":{"id":null,"name":"Myelodysplastic Syndromes","tumorForm":"LIQUID"},"tissue":"Myeloid","children":{},"parent":"MNM","level":3,"tumorForm":"LIQUID"},"pmids":["21714648","25092778","24220272"],"abstracts":[],"description":"This assertion is supported by (PMID: 24220272, 21714648, 25092778)."},{"levelOfEvidence":"LEVEL_Px1","alterations":["Oncogenic Mutations"],"tumorType":{"id":834,"code":"AMLMRC","color":"LightSalmon","name":"AML with Myelodysplasia-Related Changes","mainType":{"id":null,"name":"Leukemia","tumorForm":"LIQUID"},"tissue":"Myeloid","children":{},"parent":"AML","level":4,"tumorForm":"LIQUID"},"pmids":["25412851","25860933"],"abstracts":[],"description":"This assertion is supported by (PMID: 25860933, 25412851)."},{"levelOfEvidence":"LEVEL_Px1","alterations":["Oncogenic Mutations"],"tumorType":{"id":767,"code":"TMN","color":"LightSalmon","name":"Therapy-Related Myeloid Neoplasms","mainType":{"id":null,"name":"Leukemia","tumorForm":"LIQUID"},"tissue":"Myeloid","children":{},"parent":"AML","level":4,"tumorForm":"LIQUID"},"pmids":["25412846","25952993"],"abstracts":[],"description":"This assertion is supported by (PMID: 25412846, 25952993)."},{"levelOfEvidence":"LEVEL_Px1","alterations":["Oncogenic Mutations"],"tumorType":{"id":887,"code":"CLLSLL","color":"LimeGreen","name":"Chronic Lymphocytic Leukemia/Small Lymphocytic Lymphoma","mainType":{"id":null,"name":"Mature B-Cell Neoplasms","tumorForm":"LIQUID"},"tissue":"Lymphoid","children":{},"parent":"MBN","level":5,"tumorForm":"LIQUID"},"pmids":["23243274","24004666","20697090","19188171"