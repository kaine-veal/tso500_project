0E&VAL640GLU&https://civicdb.org/links/variants/12&BRAF_V600E_OR_NRAS_Mutation_OR_HRAS_Mutation_OR_KRAS_Mutation_OR_NF1_Inactivating_Mutation&4748&&https://civicdb.org/links/molecular-profiles/4748&NM_004333.4:c.1799T>A&NP_004324.2:p.Val600Glu&NC_000007.13:g.140453136A>T&ENST00000288602.6:c.1799T>A&CA123643&13961&376069&0.0&evidence&11696&https://civicdb.org/links/evidence/11696&35363510_(PUBMED)&SOMATIC&accepted&SENSITIVITYRESPONSE&DOES_NOT_SUPPORT&Cancer&Selumetinib_(NCIt_ID_C66939)&&&B&3&&&&&&T&Missense_Variant&BRAF&673&transcript&ENST00000288602.6&ENST00000288602.6:c.1799T>A&&V600E&12&RS113488022&VAL600GLU&V640E&VAL640GLU&https://civicdb.org/links/variants/12&BRAF_V600E_AND_NF1_Loss&5379&&https://civicdb.org/links/molecular-profiles/5379&NM_004333.4:c.1799T>A&NP_004324.2:p.Val600Glu&NC_000007.13:g.140453136A>T&ENST00000288602.6:c.1799T>A&CA123643&13961&376069&0.0&evidence&90&https://civicdb.org/links/evidence/90&24576830_(PUBMED)&SOMATIC&accepted&RESISTANCE&SUPPORTS&Melanoma&Vemurafenib_(NCIt_ID_C64768)&&&D&3&&&&&&T&Missense_Variant&BRAF&673&transcript&ENST00000288602.6&ENST00000288602.6:c.1799T>A&&V600E&12&RS113488022&VAL600GLU&V640E&VAL640GLU&https://civicdb.org/links/variants/12&BRAF_V600E_AND_GNAS_R201C&5491&&https://civicdb.org/links/molecular-profiles/5491&NM_004333.4:c.1799T>A&NP_004324.2:p.Val600Glu&NC_000007.13:g.140453136A>T&ENST00000288602.6:c.1799T>A&CA123643&13961&376069&0.0&evidence&1906&https://civicdb.org/links/evidence/1906&27729313_(PUBMED)&SOMATIC&accepted&RESISTANCE&SUPPORTS&Colorectal_Cancer&Cetuximab_(NCIt_ID_C1723)&Irinotecan_(NCIt_ID_C62040)&Vemurafenib_(NCIt_ID_C64768)&COMBINATION&&C&2&&&&&&T&Missense_Variant&BRAF&673&transcript&ENST00000288602.6&ENST00000288602.6:c.1799T>A&&V600E&12&RS113488022&VAL600GLU&V640E&VAL640GLU&https://civicdb.org/links/variants/12&BRAF_V600E_AND_ARAF_S490T&5492&&https://civicdb.org/links/molecular-profiles/5492&NM_004333.4:c.1799T>A&NP_004324.2:p.Val600Glu&NC_000007.13:g.140453136A>T&ENST00000288602.6:c.1799T>A&CA123643&13961&376069&0.0&evidence&1905&https://civicdb.org/links/evidence/1905&27729313_(PUBMED)&SOMATIC&accepted&RESISTANCE&SUPPORTS&Colorectal_Cancer&Cetuximab_(NCIt_ID_C1723)&Irinotecan_(NCIt_ID_C62040)&Vemurafenib_(NCIt_ID_C64768)&COMBINATION&&C&1&&&&&|chr7:140753336-140753336||||1|BRAF|p.V600E|||;ONCOKB_QUERY_TYPE=MUTATION;ONCOKB_QUERY_REF_GENOME=GRCh38;ONCOKB_QUERY_HUGO_SYMBOL=BRAF;ONCOKB_QUERY_ENTREZ_GENE_ID=673;ONCOKB_QUERY_ALTERATION=V600E;ONCOKB_QUERY_TUMOR_TYPE=UNKNOWN;ONCOKB_GENE_EXIST=True;ONCOKB_VARIANT_EXIST=True;ONCOKB_ALLELE_EXIST=True;ONCOKB_ONCOGENIC=Oncogenic;ONCOKB_HOTSPOT=True;ONCOKB_VUS=False;ONCOKB_EFFECT=Gain-of-function;ONCOKB_EFFECT_DESC=The class I activating exon 15 BRAF V600E mutation is located in the kinase domain of the BRAF protein and is highly recurrent in melanoma, lung and thyroid cancer, among others (PMID: 28783719, 26091043, 25079552, 23833300, 25417114, 28783719, 12068308). This mutation has been comprehensively biologically characterized and has been shown to activate the downstream MAPK pathway independent of RAS (PMID: 15035987, 12068308, 19251651, 26343582), to render BRAF constitutively activated in monomeric form (PMID: 20179705), and to retain sensitivity to RAF monomer inhibitors such as vemurafenib and dabrafenib (PMID:26343582, 28783719, 20179705, 30351999).;ONCOKB_PMIDS=25417114|20179705|23833300|26091043|26343582|12068308|30351999|25079552|28783719|19251651|15035987;ONCOKB_GENE_SUMMARY=BRAF, an intracellular kinase, is frequently mutated in melanoma, thyroid and lung cancers among others.;ONCOKB_VARIANT_SUMMARY=The BRAF V600E mutation is known to be oncogenic.;ONCOKB_TUMOR_TYPE_SUMMARY=While the RAF-inhibitor dabrafenib in combination with the MEK1/2-targeted inhibitor trametinib is FDA-approved for the treatment of patients with BRAF V600E mutant solid tumors, the clinical utility of dabrafenib in combination with trametinib in patients with BRAF V600E mutant UNKNOWN has yet to be defined.;ONCOKB_DIAGNOSTIC_IMPLICATIONS=[];ONCOKB_PROGNOSTIC_IMPLICATIONS=[];ONCOKB_TREATMENTS=[];ONCOKB_DATA_VERSION=v6.2;ONCOKB_LAST_UPDATE=11/01/2023;ONCOKB_JSON={"query":{"id":null,"referenceGenome":"GRCh38","hugoSymbol":"BRAF","entrezGeneId":673,"alteration":"V600E","alterationType":null,"svType":null,"tumorType":"UNKNOWN","consequence":null,"proteinStart":null,"proteinEnd":null,"hgvs":null,"hgvsInfo":null,"canonicalTranscript":null},"geneExist":true,"variantExist":true,"alleleExist":true,"oncogenic":"Oncogenic","mutationEffect":{"knownEffect":"Gain-of-function","description":"The class I activating exon 15 BRAF V600E mutation is located in the kinase domain of the BRAF protein and is highly recurrent in melanoma, lung and thyroid cancer, among others (PMID: 28783719, 26091043, 25079552, 23833300, 25417114, 28783719, 12068308). This mutation has been comprehensively biologically characterized and has been shown to activate the downstream MAPK pathway independent of RAS (PMID: 15035987, 12068308, 19251651, 26343582), to render BRAF constitutively activated in monomeric form (PMID: 20179705), and to retain sensitivity to RAF monomer inhibitors such as vemurafenib and dabrafenib (PMID:26343582, 28783719, 20179705, 30351999).","citations":{"pmids":["25417114","20179705","23833300","26091043","26343582","12068308","30351999","25079552","28783719","19251651","15035987"],"abstracts":[]}},"highestSensitiveLevel":null,"highestResistanceLevel":null,"highestDiagnosticImplicationLevel":null,"highestPrognosticImplicationLevel":null,"highestFdaLevel":null,"otherSignificantSensitiveLevels":[],"otherSignificantResistanceLevels":[],"VUS":false,"hotspot":true,"exon":null,"geneSummary":"BRAF, an intracellular kinase, is frequently mutated in melanoma, thyroid and lung cancers among others.","variantSummary":"The BRAF V600E mutation is known to be oncogenic.","tumorTypeSummary":"While the RAF-inhibitor dabrafenib in combination with the MEK1/2-targeted inhibitor trametinib is FDA-approved for the treatment of patients with BRAF V600E mutant solid tumors, the clinical utility of dabrafenib in combination with trametinib in patients with BRAF V600E mutant UNKNOWN has yet to be defined.","prognosticSummary":"","diagnosticSummary":"","diagnosticImplications":[],"prognosticImplications":[],"treatments":[],"dataVersion":"v6.2","lastUpdate":"11/01/2023"}	GT:OBPa:OBParc:OBPsnp:SQ:AD:AF:F1R2:F2R1:DP:OBC:SB:MB	0/1:0.05:0.00:0.95:50:250,250:0.5:125,125:125,125:500:ATG:125,125,125,125:125,125,125,125
